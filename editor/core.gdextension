[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.1
reloadable = true

[libraries]
linux.debug.x86_64 =     "res://bin/core/debug/libcadenza_core.so"
linux.release.x86_64 =   "res://bin/core/release/libcadenza_core.so"
windows.debug.x86_64 =   "res://bin/core/debug/cadenza_core.dll"
windows.release.x86_64 = "res://bin/core/release/cadenza_core.dll"
macos.debug =            "res://bin/core/debug/libcadenza_core.dylib"
macos.release =          "res://bin/core/release/libcadenza_core.dylib"
macos.debug.arm64 =      "res://bin/core/debug/libcadenza_core.dylib"
macos.release.arm64 =    "res://bin/core/release/libcadenza_core.dylib"
